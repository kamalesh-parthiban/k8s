================================================
  KARPENTER INSTALLATION ON EKS — COMPLETE GUIDE
  Cluster: my-eks-cluster | Region: us-east-2
================================================

PRE-REQUISITES
───────────────
- EKS cluster running
- kubectl configured
- AWS CLI configured
- Helm installed

================================================
STEP 1 — Set Environment Variables
================================================

export CLUSTER_NAME=my-eks-cluster
export AWS_REGION=us-east-2
export AWS_ACCOUNT_ID=382458445256
export KARPENTER_VERSION="1.12.0"
export KARPENTER_NAMESPACE="kube-system"
export AWS_PARTITION="aws"

# verify
echo $CLUSTER_NAME
echo $AWS_REGION
echo $AWS_ACCOUNT_ID
echo $KARPENTER_VERSION

================================================
STEP 2 — Get OIDC ID
================================================

aws eks describe-cluster \
  --name $CLUSTER_NAME \
  --query "cluster.identity.oidc.issuer" \
  --output text

export OIDC_ID="D4A650D7A3E49034F41641D9D5444351"
# replace with your actual OIDC ID from output

================================================
STEP 3 — Register OIDC Provider in IAM
================================================

# THIS IS CRITICAL — easy to miss!
aws iam create-open-id-connect-provider \
  --url "https://oidc.eks.us-east-2.amazonaws.com/id/${OIDC_ID}" \
  --client-id-list "sts.amazonaws.com" \
  --thumbprint-list "9e99a48a9960b14926bb7f3b02e22da2b0ab7280"

# verify
aws iam list-open-id-connect-providers

================================================
STEP 4 — Create Karpenter Controller IAM Role
================================================

# create trust policy file
cat > karpenter-trust-policy.json << 'EOF'
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::382458445256:oidc-provider/oidc.eks.us-east-2.amazonaws.com/id/D4A650D7A3E49034F41641D9D5444351"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "oidc.eks.us-east-2.amazonaws.com/id/D4A650D7A3E49034F41641D9D5444351:sub": "system:serviceaccount:kube-system:karpenter",
          "oidc.eks.us-east-2.amazonaws.com/id/D4A650D7A3E49034F41641D9D5444351:aud": "sts.amazonaws.com"
        }
      }
    }
  ]
}
EOF

# create role
aws iam create-role \
  --role-name "my-eks-cluster-karpenter" \
  --assume-role-policy-document file://karpenter-trust-policy.json \
  --query "Role.Arn" \
  --output text

