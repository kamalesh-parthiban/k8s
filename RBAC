Step 4: Get Cluster Info

# Get cluster API server URL
CLUSTER=$(kubectl config view --minify -o jsonpath='{.clusters[0].cluster.server}')

# Get cluster CA certificate
CA=$(kubectl get secret john-dev-token -n dev -o jsonpath='{.data.ca\.crt}')

Step 5: Build the Kubeconfig File

cat <<EOF > john-dev-kubeconfig.yaml
apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority-data: ${CA}
    server: ${CLUSTER}
  name: my-cluster
contexts:
- context:
    cluster: my-cluster
    namespace: dev          # locked to dev namespace
    user: john-dev
  name: john-dev-context
current-context: john-dev-context
users:
- name: john-dev
  user:
    token: ${TOKEN}
EOF
