HPA

Step 1 — Install Metrics Server:

kubectl apply -f https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml

# For EKS — add insecure tls flag
kubectl patch deployment metrics-server \
  -n kube-system \
  --type json \
  -p '[{"op":"add","path":"/spec/template/spec/containers/0/args/-","value":"--kubelet-insecure-tls"}]'

# Verify
kubectl get pods -n kube-system | grep metrics
kubectl top nodes
kubectl top pods

Step 2 — Deployment:

apiVersion: apps/v1
kind: Deployment
metadata:
  name: my-app
  namespace: default
spec:
  replicas: 2
  selector:
    matchLabels:
      app: my-app
  template:
    metadata:
      labels:
        app: my-app
    spec:
      containers:
        - name: my-app
          image: nginx:latest
          ports:
            - containerPort: 80
          resources:
            requests:
              cpu: "250m"        # ← HPA needs requests defined
              memory: "256Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"

Step 4 — HPA:

apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: my-app-hpa
  namespace: default
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: my-app              # ← must match deployment name
  minReplicas: 2              # ← minimum pods always running
  maxReplicas: 10             # ← maximum pods allowed
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 50   # ← scale when CPU > 50%
    - type: Resource
      resource:
        name: memory
        target:
          type: Utilization
          averageUtilization: 70   # ← scale when memory > 70%

kubectl get hpa
# NAME          TARGETS          MINPODS   MAXPODS   REPLICAS
# my-app-hpa   15%/50%          2         10        2
#              ↑ actual CPU ✅


